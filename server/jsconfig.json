{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@models/*": ["./src/models/*"],
      "@controllers/*": ["./src/controllers/*"],
      "@routes/*": ["./src/routes/*"],
      "@utils/*": ["./src/utils/*"]
    },
    "checkJs": true,
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["**/*.js", "scripts/**/*"],
  "exclude": ["node_modules", "dist", "logs"]
}